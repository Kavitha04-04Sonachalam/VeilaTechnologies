# Database Settings
# For PostgreSQL deployment, set this to your connection string:
# DATABASE_URL=postgresql://user:password@localhost:5432/veila
DATABASE_URL=sqlite:///./veila.db

# Authentication Settings
SECRET_KEY=veila-technologies-secret-key-very-secure-2026
